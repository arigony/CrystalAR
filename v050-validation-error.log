            <label><input id="showBonds" type="checkbox" checked /> Mostrar ligações</label>
          </div>
    
          <div class="action-row">
            <button id="resetView" class="secondary" type="button">Centralizar</button>
            <button id="downloadCif" class="secondary" type="button" disabled>Baixar CIF carregado</button>
          </div>
    
          <p id="status" class="status" role="status" aria-live="polite">Carregando a galeria local…</p>
        </div>
      </aside>
    
      <section id="infoCard" class="info-card collapsed" aria-live="polite">
        <button id="infoToggle" type="button" class="info-toggle" aria-expanded="false">
          <div class="info-icon">◇</div>
          <div class="info-summary">
            <h2 id="structureName">CrystalAR</h2>
            <p id="structureFormula">Aguardando estrutura</p>
            <small id="structureMeta">Galeria local ou CIF aberto pelo usuário</small>
          </div>
          <span class="chevron">⌃</span>
        </button>
        <div class="info-body">
          <div id="infoGrid" class="info-grid"></div>
          <div id="citationBox" class="citation-box hidden"></div>
    
          <section class="provenance-panel" aria-labelledby="provenanceTitle">
            <div class="provenance-heading">
              <div>
                <span class="eyebrow">Rastreabilidade</span>
                <h3 id="provenanceTitle">Proveniência do arquivo visualizado</h3>
              </div>
              <span class="reproducible-badge">Reprodutível</span>
            </div>
            <div id="provenanceGrid" class="provenance-grid">
              <div><span>Tipo</span><strong id="provType">—</strong></div>
              <div><span>COD ID</span><strong id="provCodId">—</strong></div>
              <div class="wide"><span>URI oficial</span><strong id="provUri">—</strong></div>
              <div><span>Incorporação</span><strong id="provDate">—</strong></div>
              <div><span>CrystalAR</span><strong id="provVersion">v0.5.0</strong></div>
              <div class="hash-item wide"><span>SHA-256 do texto CIF carregado</span><strong id="provHash">calculando…</strong></div>
            </div>
            <div class="provenance-actions">
              <button id="openOfficialCif" class="secondary" type="button" disabled>Abrir CIF oficial</button>
              <button id="copyProvenance" class="secondary" type="button">Copiar proveniência</button>
            </div>
          </section>
    
          <small class="source-note">Arquivos experimentais da galeria: cópias locais de entradas COD CC0, com COD ID e referência preservados. MOF-5 e ZIF-8 são células experimentais e podem ser mais pesados em celulares. O navegador não consulta o COD automaticamente. Grafeno: modelo 2D explicitamente identificado.</small>
        </div>
      </section>
    
      <div id="handStatus" class="hand-status hidden">AR por toque disponível</div>
    
      <div id="loading" class="loading hidden" role="status">
        <div class="spinner"></div>
        <p id="loadingText">Carregando…</p>
      </div>
    
    
      <div id="runtimeAlert" class="runtime-alert hidden" role="alert">
        <strong>O visualizador 3D não iniciou</strong>
        <p id="runtimeAlertText">Verificando os recursos necessários…</p>
        <button id="retryApp" class="primary" type="button">Recarregar visualizador</button>
      </div>
    
      <div id="toastBox" class="toast-box" aria-live="polite"></div>
    
      <script src="src/runtime-watchdog.js?v=0.5.0"></script>
      <script src="src/camera-toggle.js?v=0.5.0"></script>
